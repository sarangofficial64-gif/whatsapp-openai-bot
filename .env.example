# ---- Required ----
# Your OpenAI API key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# The ONE number the bot is allowed to chat with.
# Digits only, WITH country code, no "+" or spaces.
# Example: India (+91) 12345 67890  ->  911234567890
ALLOWED_NUMBER=911234567890

# ---- Optional (sensible defaults exist) ----
# OPENAI_MODEL=gpt-4o-mini
# SYSTEM_PROMPT=You are a helpful, concise WhatsApp assistant. Keep replies short and friendly.
# HISTORY_LIMIT=12
# LOG_LEVEL=warn

# Where the WhatsApp login session is stored.
# Locally: leave as ./auth
# On Railway: set to a path on your volume, e.g. /data/auth
# AUTH_DIR=./auth

# Where todos + settings are stored.
# Locally: leave as ./data
# On Railway: set to a path on your volume, e.g. /data/store
# DATA_DIR=./data

# Daily to-do prompt schedule (cron) + timezone.
# Default: 10:00 every day, India Standard Time.
# DAILY_CRON=0 10 * * *
# TIMEZONE=Asia/Kolkata
