# ===== Required =====
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# Digits only, WITH country code, no "+" or spaces. E.g. India (+91) 12345 67890 -> 911234567890
ALLOWED_NUMBER=911234567890

# ===== Storage paths =====
# Local: leave as-is. Railway/Render (with a volume): point both at the volume, e.g. /data/auth and /data/store
AUTH_DIR=./auth
DATA_DIR=./data

# ===== Optional — core bot behavior =====
OPENAI_MODEL=gpt-4o-mini
SYSTEM_PROMPT=You are a helpful, concise WhatsApp assistant. Keep replies short and friendly.
HISTORY_LIMIT=12
LOG_LEVEL=warn
TRANSCRIBE_MODEL=whisper-1

# ===== Optional — scheduled messages =====
DAILY_CRON=0 10 * * *
TIMEZONE=Asia/Kolkata
KEKA_LOGIN_CRON=45 9 * * *
KEKA_LOGIN_MESSAGE=🔔 Reminder: log in to Keka!
KEKA_LOGOUT_CRON=30 18 * * *
KEKA_LOGOUT_MESSAGE=🔔 Reminder: log out of Keka!

# ===== Optional — Google Drive (needed for /driveauth, file save/search) =====
# From Google Cloud Console > APIs & Services > Credentials (OAuth Client ID, type "Web application")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== Optional — Neon Postgres (needed for /store and knowledge search) =====
# From your Neon project dashboard > Connection string
DATABASE_URL=
EMBEDDING_MODEL=text-embedding-3-small

# ===== Optional — LlamaParse (better PDF extraction, falls back to local parsing if unset) =====
# From cloud.llamaindex.ai > API keys
LLAMA_CLOUD_API_KEY=

# ===== Server (OAuth callback + health check) =====
# Local: leave PORT unset (defaults to 8080), leave PUBLIC_URL unset.
# Railway: do NOT set PORT (Railway assigns it automatically). Set PUBLIC_URL to your
# public domain after enabling one in Settings > Networking, e.g. https://your-app.up.railway.app
# PORT=8080
# PUBLIC_URL=http://localhost:8080
